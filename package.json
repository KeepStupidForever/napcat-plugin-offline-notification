{
  "name": "掉线通知插件",
  "plugin": "掉线通知插件",
  "version": "1.0.0",
  "type": "module",
  "main": "index.mjs",
  "description": "NapCatQQ 掉线通知插件，当机器人掉线时自动通过 Server 酱发送微信通知",
  "author": "Forever灬笨",
  "license": "MIT",
  "keywords": [
    "napcat",
    "plugin",
    "notification",
    "offline",
    "wechat"
  ],
  "napcat": {
    "tags": [
      "工具",
      "通知"
    ],
    "minVersion": "4.14.0",
    "homepage": "https://github.com/KeepStupidForever/napcat-plugin-offline-notification"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/KeepStupidForever/napcat-plugin-offline-notification.git"
  },
  "dependencies": {
    "napcat-types": "0.0.16"
  },
  "devDependencies": {
    "@rollup/plugin-node-resolve": "^15.3.1",
    "@types/express": "^5.0.6",
    "@types/node": "^20.19.33",
    "napcat-plugin-debug-cli": "^1.2.8",
    "typescript": "^5.9.3",
    "vite": "^6.4.1",
    "ws": "^8.19.0"
  },
  "scripts": {
    "build": "vite build",
    "build:webui": "cd src/webui && pnpm install && pnpm run build",
    "dev:webui": "cd src/webui && pnpm run dev",
    "watch": "vite build --watch",
    "dev": "vite build --watch",
    "push": "vite build",
    "deploy": "vite build",
    "typecheck": "tsc --noEmit"
  }
}